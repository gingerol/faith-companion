# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Moonshot API Key (required for Kimi AI)
# Get your key at: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your-moonshot-api-key-here

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# Priest Admin Dashboard Credentials
PRIEST_ADMIN_USERNAME=priestadmin
PRIEST_ADMIN_PASSWORD=your-secure-priest-password

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Google Gemini API Key (for future AI features)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Organization Branding (used in frontend)
ORGANIZATION_NAME=Your Diocese or Parish Name
ORGANIZATION_WEBSITE=https://your-website.com

# Rate Limiting (requests per hour per IP)
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=3600

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Domain for production deployment (update docker-compose.yml accordingly)
DOMAIN=your-domain.com

# Database persistence location
DATA_PATH=./data
